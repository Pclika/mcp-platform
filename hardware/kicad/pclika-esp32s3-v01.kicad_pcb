(kicad_pcb
  (version 20230121)
  (generator "Pclika-PCB-Generator")
  (generator_version "0.1")

  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )

  (paper "A4")

  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" power "GND Plane")
    (2 "In2.Cu" power "PWR Plane")
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user "B.Fabrication")
    (49 "F.Fab" user "F.Fabrication")
  )

  (setup
    (pad_to_mask_clearance 0.05)
    (solder_mask_min_width 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (dashed_line_dash_ratio 12.0)
      (dashed_line_gap_ratio 3.0)
      (svgprecision 4)
      (plotframeref false)
      (viasonmask false)
      (mode 1)
      (useauxorigin false)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.0)
      (pdf_front_fp_property_popups true)
      (pdf_back_fp_property_popups true)
      (dxfpolygonmode true)
      (dxfimperialunits true)
      (dxfusepcbnewfont true)
      (psnegative false)
      (psa4output false)
      (plotreference true)
      (plotvalue true)
      (plotfptext true)
      (plotinvisibletext false)
      (sketchpadsonfab false)
      (subtractmaskfromsilk true)
      (outputformat 1)
      (mirror false)
      (drillshape 0)
      (scaleselection 1)
      (outputdirectory "manufacturing/gerbers/")
    )
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "+5V")
  (net 3 "+3V3")
  (net 4 "USB_VBUS")
  (net 5 "USB_D+")
  (net 6 "USB_D-")
  (net 7 "USB_CC1")
  (net 8 "USB_CC2")
  (net 9 "UART0_TX")
  (net 10 "UART0_RX")
  (net 11 "UART1_TX")
  (net 12 "UART1_RX")
  (net 13 "UART2_TX")
  (net 14 "UART2_RX")
  (net 15 "I2C_SDA")
  (net 16 "I2C_SCL")
  (net 17 "SPI_MOSI")
  (net 18 "SPI_SCK")
  (net 19 "CS_DISP")
  (net 20 "DC_DISP")
  (net 21 "PWM0")
  (net 22 "PWM1")
  (net 23 "PWM2")
  (net 24 "PWM3")
  (net 25 "WS2812_DIN")
  (net 26 "ADC1_CH0")
  (net 27 "ADC1_CH1")
  (net 28 "ADC1_CH2")
  (net 29 "ADC1_CH3")
  (net 30 "ESP_EN")
  (net 31 "GPIO0_BOOT")

  ; Board outline 65×45mm
  (gr_rect
    (start 0 0)
    (end 65.0 45.0)
    (stroke (width 0.05) (type solid))
    (layer "Edge.Cuts")
    (uuid "0f07f496-49a1-4155-a79c-1f6c050c57cc")
  )

  (gr_text "Pclika ESP32-S3 底板 v0.1"
    (at 1.0 1.0)
    (layer "F.Fab")
    (uuid "c16367a3-e3fa-47c0-8e5e-e032bf1f6cbc")
    (effects (font (size 1.2 1.2) (thickness 0.14)))
  )
  (gr_text "Generated: 2026-06-25T18:28:33"
    (at 1.0 2.5)
    (layer "F.Fab")
    (uuid "57f6ee09-4b6b-4ac5-931b-8bd82a5f4bfe")
    (effects (font (size 0.8 0.8) (thickness 0.10)))
  )
  (gr_text "PCB: 65×45mm  4-Layer FR-4  1.6mm  Black Soldermask  ENIG"
    (at 1.0 3.8)
    (layer "F.Fab")
    (uuid "3b8a649a-72fc-4d98-b04b-9285671f9a8a")
    (effects (font (size 0.8 0.8) (thickness 0.10)))
  )
  (gr_text "Seal: PCK-MMXXVI-C4A32096  Company: Pclika"
    (at 1.0 5.1)
    (layer "F.Fab")
    (uuid "f35d4772-3c06-47cd-9578-a6ba507ac20a")
    (effects (font (size 0.8 0.8) (thickness 0.10)))
  )
  (gr_text "TODO: Route traces in KiCad 8 — run export_gerbers.sh when done"
    (at 1.0 6.4)
    (layer "F.Fab")
    (uuid "cd24072f-c917-4686-9a2d-b21b28486285")
    (effects (font (size 0.9 0.9) (thickness 0.11)))
  )

  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "3bea5681-593d-4017-96f1-139947689ffe")
    (at 2.5 2.5)
    (descr "Mounting hole M2.5")
    (tags "mounting hole")
    (property "Reference" "H1" (at 0 -3.2) (layer "F.SilkS") (uuid "ce232616-3b3f-4f44-90c7-b0ab27ea493f") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_2.5" (at 0 3.2) (layer "F.Fab") (uuid "3c2646b5-8041-487e-91ca-ded852ea8e70") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.5) (layers "*.Cu" "*.Mask") (uuid "a5899591-3663-4e4f-ae5d-398a72353c01"))
    (gr_circle (center 0 0) (end 2.8 0) (stroke (width 0.05) (type solid)) (layer "F.CrtYd") (uuid "a7f66e78-7ad9-47ce-8172-d4787d958908"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "a928aa3d-6c17-4e2b-bdcb-3f89937c86a8")
    (at 62.5 2.5)
    (descr "Mounting hole M2.5")
    (tags "mounting hole")
    (property "Reference" "H2" (at 0 -3.2) (layer "F.SilkS") (uuid "38bfae1c-cd15-46e9-9855-41c359a0ec4c") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_2.5" (at 0 3.2) (layer "F.Fab") (uuid "e0a9c208-2aff-43e1-8d37-2ed0fc4d1c2f") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.5) (layers "*.Cu" "*.Mask") (uuid "e79c2333-39fc-4412-8ed2-6eeba5abb1be"))
    (gr_circle (center 0 0) (end 2.8 0) (stroke (width 0.05) (type solid)) (layer "F.CrtYd") (uuid "10af705b-9e70-4c90-8df8-c634392b95ec"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "d213a04a-19bb-4c8f-b40c-140db34da64b")
    (at 2.5 42.5)
    (descr "Mounting hole M2.5")
    (tags "mounting hole")
    (property "Reference" "H3" (at 0 -3.2) (layer "F.SilkS") (uuid "a71e262b-cedf-484c-8fd3-2439ad108682") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_2.5" (at 0 3.2) (layer "F.Fab") (uuid "d9d9f1ba-57d3-4d9a-98f0-d41ad87e3769") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.5) (layers "*.Cu" "*.Mask") (uuid "b8ea6c7f-54cd-4661-95f1-e7f75cbd09c6"))
    (gr_circle (center 0 0) (end 2.8 0) (stroke (width 0.05) (type solid)) (layer "F.CrtYd") (uuid "e7f36484-1162-4c0b-9ce7-9d029d0a0696"))
  )
  (footprint "MountingHole:MountingHole_2.7mm_M2.5"
    (layer "F.Cu")
    (uuid "fe9b5d3c-1f1a-429c-9b63-e0f18783cdad")
    (at 62.5 42.5)
    (descr "Mounting hole M2.5")
    (tags "mounting hole")
    (property "Reference" "H4" (at 0 -3.2) (layer "F.SilkS") (uuid "b3e78f27-15b8-403e-9fca-7668c44c9d84") (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "MountingHole_2.5" (at 0 3.2) (layer "F.Fab") (uuid "953fc6e3-894e-4b25-bc8e-811fb343e934") (effects (font (size 1 1) (thickness 0.15))))
    (pad "" thru_hole circle (at 0 0) (size 2.7 2.7) (drill 2.5) (layers "*.Cu" "*.Mask") (uuid "3f6d388a-fc53-45d8-9b30-dce5a549ede2"))
    (gr_circle (center 0 0) (end 2.8 0) (stroke (width 0.05) (type solid)) (layer "F.CrtYd") (uuid "b3507dbc-e2ff-48e7-8b33-89988ab53694"))
  )

  ; ESP32-S3 RF antenna keepout — no copper on F.Cu in this zone
  (zone
    (net 0)
    (net_name "")
    (layer "F.Cu")
    (uuid "590cf081-05ee-488e-b770-39000a99ee6b")
    (name "ESP32_ANT_KEEPOUT")
    (hatch edge 0.508)
    (connect_pads (clearance 0))
    (min_thickness 0.25)
    (keepout (tracks not_allowed) (vias not_allowed) (pads not_allowed) (copperpour not_allowed) (footprints not_allowed))
    (fill (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts
      (xy 41.5 10.0) (xy 52.0 10.0) (xy 52.0 35.0) (xy 41.5 35.0)
    ))
  )

  ; GND plane — In1.Cu full-board copper pour
  (zone
    (net 1)
    (net_name "GND")
    (layer "In1.Cu")
    (uuid "e8ffef6a-7531-4768-9bdb-c69831889407")
    (name "GND_PLANE")
    (hatch edge 0.508)
    (connect_pads (clearance 0.2))
    (min_thickness 0.25)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts
      (xy 0.3 0.3) (xy 64.7 0.3) (xy 64.7 44.7) (xy 0.3 44.7)
    ))
  )

  ; +3V3 plane — In2.Cu copper pour
  (zone
    (net 3)
    (net_name "+3V3")
    (layer "In2.Cu")
    (uuid "6757fbdc-d23d-4b58-a28d-ae40c4e6dae0")
    (name "PWR_PLANE")
    (hatch edge 0.508)
    (connect_pads (clearance 0.2))
    (min_thickness 0.25)
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon (pts
      (xy 0.3 0.3) (xy 64.7 0.3) (xy 64.7 44.7) (xy 0.3 44.7)
    ))
  )

  )