---
import Separator from "./Separator.astro";
import StorefrontSection from "./StorefrontSection.astro";
import StorefrontTabs from "./StorefrontTabs.astro";

type Tab = {
  href: string;
  label: string;
  current?: boolean;
};

type Props = {
  title: string;
  description: string;
  tabs: Tab[];
};

const { title, description, tabs } = Astro.props;
---

<StorefrontSection eyebrow="Account Center" title={title} description={description} />
<Separator />
<StorefrontTabs tabs={tabs} />
<slot />
