<!-- Store testing modal: hidden by default, shown by JS only if not closed before -->
<div class="announcement-modal" id="announcement-modal" style="display:none;" aria-hidden="true">
  <div class="announcement-modal__backdrop" id="announcement-backdrop"></div>
  <div class="announcement-modal__panel" role="dialog" aria-modal="true" aria-labelledby="announcement-title">
    <button class="announcement-modal__close" id="announcement-close" aria-label="Close">&times;</button>
    <p class="announcement-modal__eyebrow">PCLIKA STORE STATUS</p>
    <h2 class="announcement-modal__title" id="announcement-title">Store testing in progress</h2>
    <p class="announcement-modal__text">
      Products are not yet available for purchase. The storefront, cart flow, and account experience are currently being validated.
    </p>
    <button class="announcement-modal__action" id="announcement-confirm" type="button">Continue browsing</button>
  </div>
</div>

<!-- Cookie bar: hidden by default, shown by JS only if no prior consent -->
<div class="cookie-bar" id="cookie-bar" style="display:none;">
  <div class="cookie-bar__inner">
    <div class="cookie-bar__text">
      <strong>Cookie Consent</strong>
      <p>We use essential cookies for cart and checkout, analytics to improve the store, and marketing for relevant offers. See our <a href="/policies/cookie-policy">Cookie Policy</a> and <a href="/policies/privacy-policy">Privacy Policy</a>.</p>
    </div>
    <div class="cookie-bar__actions">
      <button class="cookie-btn cookie-btn--settings" id="cookie-btn-settings" type="button">Settings</button>
      <button class="cookie-btn cookie-btn--reject" id="cookie-btn-reject" type="button">Reject All</button>
      <button class="cookie-btn cookie-btn--accept" id="cookie-btn-accept" type="button">Accept All</button>
    </div>
  </div>
  <div class="cookie-bar__settings" id="cookie-settings-panel" style="display:none;">
    <label class="cookie-toggle"><input type="checkbox" checked disabled> <span><strong>Essential</strong> - Required for cart, checkout and security. Always enabled.</span></label>
    <label class="cookie-toggle"><input type="checkbox" id="cookie-analytics" checked> <span><strong>Analytics</strong> - Help us understand site usage to improve the store.</span></label>
    <label class="cookie-toggle"><input type="checkbox" id="cookie-marketing" checked> <span><strong>Marketing</strong> - Enable relevant product recommendations.</span></label>
    <button class="cookie-btn cookie-btn--accept" id="cookie-btn-save" type="button">Save Preferences</button>
  </div>
</div>

<style>
  .announcement-modal {
    position: fixed;
    inset: 0;
    z-index: 10020;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .announcement-modal__backdrop {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top, rgba(34, 185, 154, 0.16), transparent 40%),
      rgba(6, 8, 10, 0.64);
    backdrop-filter: blur(8px);
  }
  .announcement-modal__panel {
    position: relative;
    width: min(32rem, 100%);
    padding: 2rem 2rem 1.75rem;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.18);
    display: grid;
    gap: 0.9rem;
  }
  .announcement-modal__close {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.62);
  }
  .announcement-modal__eyebrow {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: #22b99a;
  }
  .announcement-modal__title {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    line-height: 0.92;
  }
  .announcement-modal__text {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.65;
    color: rgba(0, 0, 0, 0.66);
    max-width: 30rem;
  }
  .announcement-modal__action {
    justify-content: center;
    align-items: center;
    min-height: 2.9rem;
    padding: 0.85rem 1.25rem;
    background: #111417;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
  }
  .announcement-modal__action:hover,
  .announcement-modal__close:hover {
    color: inherit;
    opacity: 0.82;
  }

  .cookie-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10000;
    background: #111417;
    color: #dde4e1;
    font-family: inherit;
    padding: 1rem;
    box-shadow: 0 -0.5rem 2rem rgba(0, 0, 0, 0.3);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .cookie-bar__inner {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    max-width: 1100px;
    margin: 0 auto;
    flex-wrap: wrap;
  }
  .cookie-bar__text {
    flex: 1;
    min-width: 260px;
  }
  .cookie-bar__text strong {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.9rem;
    color: #fff;
  }
  .cookie-bar__text p {
    margin: 0;
    color: #a1ada8;
    line-height: 1.6;
  }
  .cookie-bar__text a {
    color: #22b99a;
    text-decoration: underline;
  }
  .cookie-bar__actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-shrink: 0;
  }
  .cookie-btn {
    padding: 0.55rem 1.2rem;
    font-size: 0.76rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    border: 0;
    transition: opacity 0.2s;
  }
  .cookie-btn:hover {
    opacity: 0.85;
  }
  .cookie-btn--accept {
    background: #22b99a;
    color: #fff;
  }
  .cookie-btn--reject {
    background: transparent;
    color: #a1ada8;
    border: 1px solid #3a4045;
  }
  .cookie-btn--settings {
    background: transparent;
    color: #a1ada8;
    text-decoration: underline;
    padding: 0.55rem 0.5rem;
  }
  .cookie-bar__settings {
    max-width: 1100px;
    margin: 0.5rem auto 0;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .cookie-toggle {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    cursor: pointer;
    color: #a1ada8;
  }
  .cookie-toggle strong {
    color: #dde4e1;
  }
  .cookie-toggle input {
    margin-top: 0.2rem;
  }

  @media screen and (max-width: 40em) {
    .announcement-modal {
      padding: 1rem;
    }
    .announcement-modal__panel {
      padding: 1.6rem 1.25rem 1.25rem;
    }
    .announcement-modal__action {
      width: 100%;
    }
    .cookie-bar__actions {
      width: 100%;
      flex-wrap: wrap;
    }
    .cookie-btn {
      flex: 1 1 9rem;
      justify-content: center;
    }
  }
</style>

<script>
  (function() {
    "use strict";

    var ann = document.getElementById("announcement-modal");
    var closeAnnouncement = function() {
      if (!ann) return;
      localStorage.setItem("_ann_closed", "1");
      ann.style.display = "none";
      ann.setAttribute("aria-hidden", "true");
    };

    if (ann && !localStorage.getItem("_ann_closed")) {
      ann.style.display = "flex";
      ann.setAttribute("aria-hidden", "false");
      document.getElementById("announcement-close")?.addEventListener("click", closeAnnouncement);
      document.getElementById("announcement-confirm")?.addEventListener("click", closeAnnouncement);
      document.getElementById("announcement-backdrop")?.addEventListener("click", closeAnnouncement);
    }

    var bar = document.getElementById("cookie-bar");
    if (!bar) return;

    if (localStorage.getItem("_ck")) {
      return;
    }

    bar.style.display = "block";

    function hideBar() {
      bar.style.transition = "opacity 0.3s";
      bar.style.opacity = "0";
      setTimeout(function() {
        bar.style.display = "none";
      }, 300);
    }

    function acceptAll() {
      var a = document.getElementById("cookie-analytics");
      if (a) a.checked = true;
      var m = document.getElementById("cookie-marketing");
      if (m) m.checked = true;
      localStorage.setItem("_ck", "all");
      hideBar();
    }

    function rejectAll() {
      var a = document.getElementById("cookie-analytics");
      if (a) a.checked = false;
      var m = document.getElementById("cookie-marketing");
      if (m) m.checked = false;
      localStorage.setItem("_ck", "reject");
      hideBar();
    }

    function savePrefs() {
      localStorage.setItem("_ck", "custom");
      hideBar();
    }

    document.getElementById("cookie-btn-accept")?.addEventListener("click", acceptAll);
    document.getElementById("cookie-btn-reject")?.addEventListener("click", rejectAll);
    document.getElementById("cookie-btn-save")?.addEventListener("click", savePrefs);
    document.getElementById("cookie-btn-settings")?.addEventListener("click", function() {
      var p = document.getElementById("cookie-settings-panel");
      if (p) p.style.display = p.style.display === "none" ? "block" : "none";
    });
  })();
</script>
