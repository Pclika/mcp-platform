---
import Separator from "../components/Separator.astro";
import Logo from "../assets/images/logo.svg";
---

<Separator />
<footer>
  <p>
    <a href="/"><Logo width={120} /></a>
  </p>
  <p>PCLIKA STORE</p>
  <p>
    <a href="/">MCPBase</a>
    &nbsp;|&nbsp;
    <a href="/hello">Hello</a>
    &nbsp;|&nbsp;
    <a href="/taxons/board">Boards</a>
    &nbsp;|&nbsp;
    <a href="/taxons/sensor">Sensors</a>
    &nbsp;|&nbsp;
    <a href="/taxons/bridge">Bridge</a>
    &nbsp;|&nbsp;
    <a href="https://pclika.com/" target="_blank" rel="noopener">pclika.com</a>
    &nbsp;|&nbsp;
    <a href="https://github.com/Pclika" target="_blank" rel="noopener">GitHub</a>
  </p>

  <div class="footer-legal">
    <div>
      <a href="/policies/privacy-policy">Privacy Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/returns-refunds">Returns &amp; Refunds</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/shipping-policy">Shipping Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/terms-of-service">Terms of Service</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/contact-us">Contact Us</a>
    </div>
    <div>
      <a href="/policies/cookie-policy">Cookie Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/faq">FAQ</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/payment-policy">Payment Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/warranty-policy">Warranty Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/policies/age-verification">Age Verification</a>
      <span aria-hidden="true">|</span>
      <button id="cookie-reset" type="button">Cookie Settings</button>
    </div>
  </div>

  <p class="footer-copy">&copy; 2026 Pclika Ltd. All rights reserved.</p>
</footer>

<style>
  footer {
    padding: 2rem 0;
  }
  p {
    margin: 0;
    font-weight: bold;
    line-height: 1.4;
    text-align: center;
    color: var(--color-text-alt);
  }
  .footer-legal {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    margin-top: 1.2rem;
    font-size: 0.6rem;
    color: var(--color-faded);
  }
  .footer-legal div {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.3rem 0.5rem;
  }
  .footer-legal a {
    color: var(--color-faded);
    text-decoration: none;
    white-space: nowrap;
  }
  .footer-legal a:hover {
    color: var(--color-text-alt);
  }
  .footer-legal span {
    color: var(--color-faded);
    opacity: 0.4;
  }
  .footer-legal button {
    background: none;
    border: 0;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.6rem;
    color: var(--color-faded);
    padding: 0;
    text-decoration: underline;
  }
  .footer-legal button:hover {
    color: var(--color-text-alt);
  }
  .footer-copy {
    margin-top: 1rem;
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-faded);
  }
</style>

<script>
  document.getElementById("cookie-reset")?.addEventListener("click", function() {
    localStorage.removeItem("_ck");
    localStorage.removeItem("pclika_consent");
    location.reload();
  });
</script>
