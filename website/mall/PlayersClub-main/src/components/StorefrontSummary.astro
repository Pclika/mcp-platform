---
interface Props {
  title?: string;
  items?: number;
  subtotal?: string;
  shipping?: string;
  tax?: string;
  total: string;
}

const {
  title = "Order Summary",
  items,
  subtotal,
  shipping,
  tax,
  total,
} = Astro.props as Props;
---

<aside class="storefront-summary">
  <h3>{title}</h3>
  <dl>
    {typeof items === "number" && (
      <>
        <dt>Items</dt>
        <dd>{items}</dd>
      </>
    )}
    {subtotal && (
      <>
        <dt>Subtotal</dt>
        <dd>{subtotal}</dd>
      </>
    )}
    {shipping && (
      <>
        <dt>Shipping</dt>
        <dd>{shipping}</dd>
      </>
    )}
    {tax && (
      <>
        <dt>Tax</dt>
        <dd>{tax}</dd>
      </>
    )}
    <dt>Total</dt>
    <dd class="storefront-summary__total">{total}</dd>
  </dl>
  <slot />
</aside>

<style>
  .storefront-summary {
    display: grid;
    gap: 1rem;
    padding: 1.15rem;
    border: 1px solid var(--border-color);
    background: var(--color-placeholder);
  }

  .storefront-summary h3 {
    margin: 0;
    font-size: 1rem;
  }

  .storefront-summary dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem 1rem;
    margin: 0;
  }

  .storefront-summary dt,
  .storefront-summary dd {
    margin: 0;
  }

  .storefront-summary dd {
    text-align: right;
    color: var(--color-text-alt);
  }

  .storefront-summary__total {
    font-weight: 700;
    color: var(--color-text);
  }
</style>
