---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Separator from "../components/Separator.astro";

export const getStaticPaths = async () => {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { product_id: product.id },
    props: { products, product },
  }));
};

type Props = {
  products: CollectionEntry<"products">[];
  product: CollectionEntry<"products">;
};

const { products, product } = Astro.props;
const { Content } = await render(product);

const currentIndex = products.findIndex((p) => p.id === product.id);
const nextIndex = (currentIndex + 1) % products.length;
const nextProduct = products[nextIndex];

// Build image gallery
const allImages = [
  { src: product.data.image.src, alt: product.data.image.alt },
  ...(product.data.images || []),
];

// ── Combo bundles ──
// Each bundle: { label, ids (product ids to include), desc }
const BUNDLES: { label: string; ids: string[]; desc: string }[] = [
  {
    label: "Dev Kit",
    ids: ["esp32-s3-baseboard", "oled-display-128x64", "temp-humidity-sensor"],
    desc: "Baseboard + display + sensor — everything you need to start prototyping with the Pclika MCP bridge.",
  },
  {
    label: "Bridge Kit",
    ids: ["esp32-s3-baseboard", "usb-serial-bridge"],
    desc: "Baseboard + USB bridge — the minimal stack to expose hardware tools to AI clients.",
  },
  {
    label: "Motion Pack",
    ids: ["esp32-s3-baseboard", "servo-driver-shield", "stepper-motor-driver"],
    desc: "Baseboard + servo shield + stepper driver — full motion control for robotics projects.",
  },
  {
    label: "Wireless Kit",
    ids: ["esp32-s3-baseboard", "wifi-ble-combo", "lipo-battery-shield"],
    desc: "Baseboard + wireless module + battery — untethered sensor mesh endpoint.",
  },
  {
    label: "Industrial Pack",
    ids: ["esp32-s3-baseboard", "can-bus-transceiver", "gpio-breakout"],
    desc: "Baseboard + CAN + GPIO breakout — automotive and factory-floor ready.",
  },
];

// Find bundles that include the current product
const matchingBundles = BUNDLES.filter(b => b.ids.includes(product.id));

// Resolve bundle products
const bundleData = matchingBundles.map(b => ({
  ...b,
  items: b.ids
    .map(id => products.find(p => p.id === id))
    .filter(Boolean) as CollectionEntry<"products">[],
  totalPrice: b.ids.reduce((sum, id) => {
    const p = products.find(p => p.id === id);
    if (!p) return sum;
    const price = parseFloat(p.data.price.replace(/[^0-9.]/g, ''));
    return sum + (isNaN(price) ? 0 : price);
  }, 0),
}));

// More in same category
const categoryProducts = products.filter(
  (p) => p.data.category === product.data.category && p.id !== product.id
);
---

<BaseLayout title={`${product.data.name} — PCLIKA`} description={product.data.sku}>
  <section>
    <header class="title-header">
      <h2>
        {product.data.name}
        <span class="faded">({product.data.category})</span>
      </h2>
      <div>
        <a class="back" href="/">View all</a>
        <span class="faded">/</span>
        <a href={`/${nextProduct.id}`}>Next</a>
      </div>
    </header>
    <Separator />

    <!-- Product content: image gallery + overview + specs -->
    <div class="content-wrap">
      <!-- Image gallery -->
      <div class="gallery">
        {allImages.map((img, i) => (
          <img
            class="gallery-img fade-in"
            src={img.src}
            alt={img.alt}
            data-index={i}
          />
        ))}
        {allImages.length > 1 && (
          <div class="gallery-thumbs">
            {allImages.map((img, i) => (
              <button class="thumb" type="button" data-index={i}>
                <img src={img.src} alt={img.alt} />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Text content -->
      <div class="content">
        <h3>Overview</h3>
        <Content />

        <dl class="product-specs">
          {product.data.specs.chip && product.data.specs.chip !== '--' && (
            <><dt>Chip</dt><dd>{product.data.specs.chip}</dd></>
          )}
          {product.data.specs.voltage && product.data.specs.voltage !== '--' && (
            <><dt>Voltage</dt><dd>{product.data.specs.voltage}</dd></>
          )}
          {product.data.specs.protocol && product.data.specs.protocol !== '--' && (
            <><dt>Protocol</dt><dd>{product.data.specs.protocol}</dd></>
          )}
          {product.data.specs.interface && product.data.specs.interface !== '--' && (
            <><dt>Interface</dt><dd>{product.data.specs.interface}</dd></>
          )}
          {product.data.specs.pins && product.data.specs.pins !== '--' && (
            <><dt>Pins</dt><dd>{product.data.specs.pins}</dd></>
          )}
          {product.data.specs.resolution && product.data.specs.resolution !== '--' && (
            <><dt>Resolution</dt><dd>{product.data.specs.resolution}</dd></>
          )}
          {product.data.specs.channels && product.data.specs.channels !== '--' && (
            <><dt>Channels</dt><dd>{product.data.specs.channels}</dd></>
          )}
          {product.data.specs.dimensions && product.data.specs.dimensions !== '--' && (
            <><dt>Dimensions</dt><dd>{product.data.specs.dimensions}</dd></>
          )}
          {product.data.specs.weight && product.data.specs.weight !== '--' && (
            <><dt>Weight</dt><dd>{product.data.specs.weight}</dd></>
          )}
        </dl>

        <!-- Price + Buy -->
        <div class="buy-block">
          <p class="price">{product.data.price}</p>
          <p class="sku">SKU: {product.data.sku}</p>
          <button class="buy-btn">Add to Cart</button>
        </div>
      </div>
    </div>

    <!-- Combo bundles -->
    {bundleData.length > 0 && (
      <div class="combo-section">
        <h3>Recommended Combos</h3>
        <Separator />
        <div class="combo-list">
          {bundleData.map(bundle => (
            <article class="combo-card">
              <div class="combo-header">
                <h4>{bundle.label}</h4>
                <span class="combo-price">${bundle.totalPrice.toFixed(2)}</span>
              </div>
              <p class="combo-desc">{bundle.desc}</p>
              <ul class="combo-items">
                {bundle.items.map(item => (
                  <li>
                    <a href={`/${item.id}`}>
                      <span class={item.id === product.id ? "combo-current" : ""}>
                        {item.data.name}
                      </span>
                    </a>
                    <span class="faded">{item.data.price}</span>
                  </li>
                ))}
              </ul>
              <button class="buy-btn buy-btn--small">Add Combo to Cart</button>
            </article>
          ))}
        </div>
      </div>
    )}

    <!-- More in this category -->
    {categoryProducts.length > 0 && (
      <div class="related-section">
        <h3>More in {product.data.category}</h3>
        <Separator />
        <div class="product-grid">
          {categoryProducts.map((p) => (
            <a
              href={`/${p.id}`}
              class="product"
              style={`--image: url('${p.data.image.src}');`}
              data-astro-prefetch
              aria-label={p.data.name}
            ></a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* ── Content wrap ── */
  .content-wrap {
    display: grid;
    gap: 2.5rem;
    padding: 2rem 0 3rem;
    grid-template-columns: 100%;
  }
  @media screen and (min-width: 50em) {
    .content-wrap {
      grid-template-columns: 40vw 1fr;
    }
  }

  /* ── Gallery ── */
  .gallery {
    position: relative;
    aspect-ratio: 0.8;
    background: var(--color-placeholder);
  }
  .gallery-img {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .gallery-img.active {
    opacity: 1;
    position: relative;
  }
  .gallery-thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .thumb {
    width: 4rem;
    height: 5rem;
    overflow: hidden;
    opacity: 0.45;
    transition: opacity 0.2s;
    padding: 0;
    border: 0;
    cursor: pointer;
    background: var(--color-placeholder);
  }
  .thumb.active {
    opacity: 1;
    outline: 1px solid var(--color-text);
    outline-offset: 2px;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Content text ── */
  .content {
    max-width: 520px;
  }
  .content h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }
  .content :global(h2) {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }
  .content :global(p) {
    line-height: 1.65;
    font-weight: 500;
    margin: 0 0 1rem;
    color: var(--color-text-alt);
  }
  .content :global(ul), .content :global(ol) {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .content :global(li) {
    line-height: 1.7;
    font-weight: 500;
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--color-faded);
  }
  .content :global(li:last-child) {
    border-bottom: none;
  }

  /* ── Specs table ── */
  .product-specs {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.6rem 1.5rem;
    margin: 2rem 0;
  }
  .product-specs dt {
    font-weight: 700;
    font-size: 0.85rem;
  }
  .product-specs dd {
    margin: 0;
    color: var(--color-text-alt);
    font-weight: 500;
    font-size: 0.9rem;
  }

  /* ── Buy block ── */
  .buy-block {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }
  .price {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }
  .sku {
    font-size: var(--font-size-s);
    color: var(--color-faded);
    margin: 0;
    flex: 1;
  }
  .buy-btn {
    background: var(--color-text);
    color: var(--color-bg);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.85rem 2rem;
    cursor: pointer;
    transition: opacity 0.25s;
  }
  .buy-btn:hover {
    opacity: 0.8;
    color: var(--color-bg);
  }
  .buy-btn--small {
    padding: 0.55rem 1.25rem;
    font-size: 0.78rem;
  }

  /* ── Combo section ── */
  .combo-section {
    margin-top: 5rem;
  }
  .combo-section h3 {
    margin-bottom: 0.75rem;
  }
  .combo-list {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  @media screen and (min-width: 44em) {
    .combo-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (min-width: 60em) {
    .combo-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .combo-card {
    border: 1px solid var(--border-color);
    padding: 1.25rem;
  }
  .combo-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .combo-header h4 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }
  .combo-price {
    font-weight: 700;
    font-size: 1.1rem;
  }
  .combo-desc {
    font-size: var(--font-size-s);
    color: var(--color-text-alt);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }
  .combo-items {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
  }
  .combo-items li {
    display: flex;
    justify-content: space-between;
    font-size: 0.82rem;
    line-height: 1.8;
  }
  .combo-current {
    font-weight: 700;
    color: var(--color-text);
  }
  .combo-items a {
    color: var(--color-text-alt);
  }
  .combo-items .faded {
    font-size: 0.78rem;
  }

  /* ── Related section ── */
  .related-section {
    margin-top: 5rem;
  }
  .related-section h3 {
    margin-bottom: 0.75rem;
  }

  .product-grid {
    display: grid;
    width: 100%;
    grid-template-columns: repeat(2, calc(100% / 2));
    margin: 1rem 0 4rem;
    gap: 2px;
  }
  @media screen and (min-width: 30em) {
    .product-grid { grid-template-columns: repeat(4, calc(100% / 4)); }
  }
  @media screen and (min-width: 50em) {
    .product-grid { grid-template-columns: repeat(7, calc(100% / 7)); }
  }

  a.product {
    background-image: var(--image);
    background-size: cover;
    background-position: 50% 0%;
    aspect-ratio: 0.8;
    display: block;
  }
</style>

<script>
  // Image gallery switcher
  const imgs = document.querySelectorAll('.gallery-img');
  const thumbs = document.querySelectorAll('.thumb');
  if (imgs.length > 1) {
    imgs[0].classList.add('active');
    if (thumbs.length) thumbs[0].classList.add('active');

    thumbs.forEach(thumb => {
      thumb.addEventListener('click', (e) => {
        e.preventDefault();
        const idx = parseInt(thumb.dataset.index);
        imgs.forEach(i => i.classList.remove('active'));
        thumbs.forEach(t => t.classList.remove('active'));
        imgs[idx].classList.add('active');
        thumb.classList.add('active');
      });
    });
  }

  // ── Cart state ──
  function getCart() {
    try { return JSON.parse(localStorage.getItem('_cart') || '[]'); } catch(e) { return []; }
  }
  function setCart(items) { localStorage.setItem('_cart', JSON.stringify(items)); }

  function updateCartBadge() {
    var cart = getCart();
    var count = cart.reduce(function(s, i) { return s + (i.qty || 1); }, 0);
    var badges = document.querySelectorAll('.cart-badge');
    badges.forEach(function(b) { b.textContent = count; });
    // Also update header badge if DOM has it
    var headerBadge = document.querySelector('.cart-badge');
    if (headerBadge) {
      if (count > 0) { headerBadge.textContent = count; headerBadge.style.display = 'flex'; }
      else { headerBadge.style.display = 'none'; }
    }
  }

  // Buy button handler
  document.querySelectorAll('.buy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      // Find product info from the page
      var nameEl = document.querySelector('.buy-block');
      var name = '';
      var sku = '';
      var price = '';
      if (nameEl) {
        var priceEl = nameEl.querySelector('.price');
        if (priceEl) price = priceEl.textContent.trim();
        var skuEl = nameEl.querySelector('.sku');
        if (skuEl) sku = skuEl.textContent.replace('SKU:', '').trim();
      }
      // Get product name from page title
      var titleEl = document.querySelector('title');
      if (titleEl) name = titleEl.textContent.replace(' — PCLIKA', '').trim();

      // Check if it's a combo button
      var isCombo = btn.classList.contains('buy-btn--small');
      if (isCombo) {
        // Add all combo items
        var items = btn.closest('.combo-card');
        if (items) {
          var links = items.querySelectorAll('.combo-items a');
          links.forEach(function(link) {
            var itemName = link.textContent.trim();
            if (itemName) {
              var cart = getCart();
              var existing = cart.find(function(i) { return i.name === itemName; });
              if (existing) { existing.qty = (existing.qty || 1) + 1; }
              else { cart.push({ name: itemName, price: price, qty: 1 }); }
              setCart(cart);
            }
          });
        }
      } else {
        var cart = getCart();
        var existing = cart.find(function(i) { return i.name === name || i.sku === sku; });
        if (existing) { existing.qty = (existing.qty || 1) + 1; }
        else { cart.push({ name: name, sku: sku, price: price, qty: 1 }); }
        setCart(cart);
      }

      updateCartBadge();
      btn.textContent = 'Added ✓';
      btn.style.background = '#22B99A';
      setTimeout(function() {
        btn.textContent = isCombo ? 'Add Combo to Cart' : 'Add to Cart';
        btn.style.background = '';
      }, 2000);
    });
  });

  // Init badge on page load
  updateCartBadge();
</script>
