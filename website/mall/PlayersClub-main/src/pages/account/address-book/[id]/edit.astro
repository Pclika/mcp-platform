---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import AccountShell from "../../../../components/AccountShell.astro";
import StorefrontForm from "../../../../components/StorefrontForm.astro";
import { mockAddresses } from "../../../../lib/storefront";
import { storefrontAliases, syliusPaths } from "../../../../lib/sylius";

export const getStaticPaths = () =>
  mockAddresses.map((address) => ({
    params: { id: address.id },
  }));

const { id = "" } = Astro.params;
const address = mockAddresses.find((entry) => entry.id === id) ?? mockAddresses[0];

const title = "Edit Address | PCLIKA";
const tabs = [
  { href: storefrontAliases.accountDashboard, label: "Dashboard" },
  { href: storefrontAliases.accountOrders, label: "Orders" },
  { href: storefrontAliases.accountAddressBook, label: "Addresses", current: true },
  { href: storefrontAliases.accountProfile, label: "Profile" },
  { href: storefrontAliases.accountPassword, label: "Password" },
];
---

<BaseLayout title={title} description="Edit address aligned to the Sylius account address-book edit route.">
  <section>
    <AccountShell
      title="Edit Address"
      description="This edit form mirrors the Sylius customer address-book edit action and completes the storefront address workflow."
      tabs={tabs}
    >
      <StorefrontForm action={syliusPaths.accountAddressBookEdit(address.id)} method="post">
        <p class="storefront-help">Target Sylius route: <code>{syliusPaths.accountAddressBookEdit(address.id)}</code></p>
        <div class="storefront-form__grid storefront-form__grid--2">
          <label><span>Label</span><input name="addressBook[label]" value={address.label} /></label>
          <label><span>Name</span><input name="addressBook[fullName]" value={address.name} /></label>
        </div>
        <label><span>Street</span><input name="addressBook[street]" value={address.street} /></label>
        <div class="storefront-form__grid storefront-form__grid--2">
          <label><span>City</span><input name="addressBook[city]" value={address.city} /></label>
          <label><span>Province / State</span><input name="addressBook[province]" value={address.province} /></label>
        </div>
        <div class="storefront-form__grid storefront-form__grid--2">
          <label><span>Postcode</span><input name="addressBook[postcode]" value={address.postcode} /></label>
          <label><span>Country</span><input name="addressBook[country]" value={address.country} /></label>
        </div>
        <label><span>Phone</span><input name="addressBook[phone]" value={address.phone} /></label>
        <div class="storefront-form__actions">
          <a class="storefront-button storefront-button--secondary" href={storefrontAliases.accountAddressBook}>Back</a>
          <button type="submit">Update address</button>
        </div>
      </StorefrontForm>
    </AccountShell>
  </section>
</BaseLayout>
