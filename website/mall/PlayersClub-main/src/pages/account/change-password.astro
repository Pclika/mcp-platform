---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AccountShell from "../../components/AccountShell.astro";
import StorefrontForm from "../../components/StorefrontForm.astro";
import { storefrontAliases, syliusPaths } from "../../lib/sylius";

const title = "Change Password | PCLIKA";
const tabs = [
  { href: storefrontAliases.accountDashboard, label: "Dashboard" },
  { href: storefrontAliases.accountOrders, label: "Orders" },
  { href: storefrontAliases.accountAddressBook, label: "Addresses" },
  { href: storefrontAliases.accountProfile, label: "Profile" },
  { href: storefrontAliases.accountPassword, label: "Password", current: true },
];
---

<BaseLayout title={title} description="Password change page aligned to the Sylius storefront account password route.">
  <section>
    <AccountShell
      title="Change Password"
      description="This page should submit to the Sylius account password change route and policy."
      tabs={tabs}
    >
      <StorefrontForm action={syliusPaths.accountChangePassword()} method="post">
        <label><span>Current password</span><input type="password" name="currentPassword" /></label>
        <label><span>New password</span><input type="password" name="newPassword[first]" /></label>
        <label><span>Confirm new password</span><input type="password" name="newPassword[second]" /></label>
        <div class="storefront-form__actions">
          <button type="submit">Update password</button>
        </div>
      </StorefrontForm>
    </AccountShell>
  </section>
</BaseLayout>
