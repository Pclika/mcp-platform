---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AccountShell from "../../components/AccountShell.astro";
import StorefrontCardGrid from "../../components/StorefrontCardGrid.astro";
import StorefrontCard from "../../components/StorefrontCard.astro";
import { storefrontAliases } from "../../lib/sylius";

const title = "Account Dashboard | PCLIKA";
const tabs = [
  { href: storefrontAliases.accountDashboard, label: "Dashboard", current: true },
  { href: storefrontAliases.accountOrders, label: "Orders" },
  { href: storefrontAliases.accountAddressBook, label: "Addresses" },
  { href: storefrontAliases.accountProfile, label: "Profile" },
  { href: storefrontAliases.accountPassword, label: "Password" },
];
---

<BaseLayout title={title} description="Sylius-style account dashboard overview.">
  <section>
    <AccountShell
      title="Dashboard"
      description="Quick access to your orders, saved addresses, and account actions."
      tabs={tabs}
    >
      <StorefrontCardGrid>
        <StorefrontCard title="Orders" subtitle="Track active shipments" href={storefrontAliases.accountOrders} actionLabel="Open orders">
          <p>Monitor fulfillment states, shipping updates, and invoice traces for each MCU or kit purchase.</p>
        </StorefrontCard>
        <StorefrontCard title="Address book" subtitle="Shipping presets" href={storefrontAliases.accountAddressBook} actionLabel="Open addresses">
          <p>Save regional warehouse, office, or reseller destinations used during checkout.</p>
        </StorefrontCard>
        <StorefrontCard title="Security" subtitle="Password & recovery" href={storefrontAliases.accountPassword} actionLabel="Change password">
          <p>Keep your account secure and aligned with the storefront identity layer.</p>
        </StorefrontCard>
      </StorefrontCardGrid>
    </AccountShell>
  </section>
</BaseLayout>
