---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AccountShell from "../../components/AccountShell.astro";
import StorefrontCardGrid from "../../components/StorefrontCardGrid.astro";
import StorefrontCard from "../../components/StorefrontCard.astro";
import { mockOrders, mockAddresses } from "../../lib/storefront";
import { storefrontAliases } from "../../lib/sylius";

const title = "Account Center | PCLIKA";
const tabs = [
  { href: storefrontAliases.accountDashboard, label: "Dashboard", current: true },
  { href: storefrontAliases.accountOrders, label: "Orders" },
  { href: storefrontAliases.accountAddressBook, label: "Addresses" },
  { href: storefrontAliases.accountProfile, label: "Profile" },
  { href: storefrontAliases.accountPassword, label: "Password" },
];
---

<BaseLayout title={title} description="Account dashboard aligned to Sylius storefront account routes.">
  <section>
    <AccountShell
      title="Account Dashboard"
      description="A storefront dashboard that mirrors the Sylius account root and dashboard routes."
      tabs={tabs}
    >
      <StorefrontCardGrid>
        <StorefrontCard title="Recent order" subtitle={mockOrders[0].number} href={storefrontAliases.accountOrders} actionLabel="View all orders">
          <p>{mockOrders[0].state} / {mockOrders[0].paymentState} / total {mockOrders[0].total}</p>
        </StorefrontCard>
        <StorefrontCard title="Default address" subtitle={mockAddresses[0].label} href={storefrontAliases.accountAddressBook} actionLabel="Manage addresses">
          <p>{mockAddresses[0].street}, {mockAddresses[0].city}, {mockAddresses[0].province}</p>
        </StorefrontCard>
        <StorefrontCard title="Profile status" subtitle="Sylius account profile" href={storefrontAliases.accountProfile} actionLabel="Edit profile">
          <p>Use this area to sync profile, locale, billing contact, and future storefront preferences.</p>
        </StorefrontCard>
      </StorefrontCardGrid>
    </AccountShell>
  </section>
</BaseLayout>
