---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AccountShell from "../../../components/AccountShell.astro";
import StorefrontCard from "../../../components/StorefrontCard.astro";
import StorefrontCardGrid from "../../../components/StorefrontCardGrid.astro";
import { mockOrders } from "../../../lib/storefront";
import { storefrontAliases } from "../../../lib/sylius";

export const getStaticPaths = () =>
  mockOrders.map((order) => ({
    params: { number: order.number },
    props: { order },
  }));

const { order } = Astro.props;
const title = `${order.number} | PCLIKA`;
const tabs = [
  { href: storefrontAliases.accountDashboard, label: "Dashboard" },
  { href: storefrontAliases.accountOrders, label: "Orders", current: true },
  { href: storefrontAliases.accountAddressBook, label: "Addresses" },
  { href: storefrontAliases.accountProfile, label: "Profile" },
  { href: storefrontAliases.accountPassword, label: "Password" },
];
---

<BaseLayout title={title} description="Order detail page aligned to Sylius account order detail route.">
  <section>
    <AccountShell
      title={`Order ${order.number}`}
      description="The detail page should eventually render the real Sylius order timeline, totals, shipments, and payment transactions."
      tabs={tabs}
    >
      <StorefrontCardGrid>
        <StorefrontCard title="Status" subtitle={order.state}>
          <p>Payment: {order.paymentState}</p>
          <p>Shipment: {order.shipmentState}</p>
        </StorefrontCard>
        <StorefrontCard title="Order total" subtitle={order.total}>
          <p>Placed {order.placedAt}</p>
          <p>{order.items} item(s)</p>
        </StorefrontCard>
        <StorefrontCard title="Follow up" subtitle="Sylius order actions">
          <p>This route should later expose invoice download, shipment tracking, and payment retry when applicable.</p>
        </StorefrontCard>
      </StorefrontCardGrid>
    </AccountShell>
  </section>
</BaseLayout>
