---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AccountShell from "../../../components/AccountShell.astro";
import StorefrontCardGrid from "../../../components/StorefrontCardGrid.astro";
import StorefrontCard from "../../../components/StorefrontCard.astro";
import { mockOrders } from "../../../lib/storefront";
import { storefrontAliases } from "../../../lib/sylius";

const title = "My Orders | PCLIKA";
const tabs = [
  { href: storefrontAliases.accountDashboard, label: "Dashboard" },
  { href: storefrontAliases.accountOrders, label: "Orders", current: true },
  { href: storefrontAliases.accountAddressBook, label: "Addresses" },
  { href: storefrontAliases.accountProfile, label: "Profile" },
  { href: storefrontAliases.accountPassword, label: "Password" },
];
---

<BaseLayout title={title} description="Account order list aligned to Sylius storefront routes.">
  <section>
    <AccountShell
      title="My Orders"
      description="Each order card here should correspond to a Sylius customer order resource."
      tabs={tabs}
    >
      <StorefrontCardGrid>
        {mockOrders.map((order) => (
          <StorefrontCard
            title={order.number}
            subtitle={`${order.state} / ${order.paymentState}`}
            href={`${storefrontAliases.accountOrders}/${order.number}`}
            actionLabel="Open order"
          >
            <p>Total {order.total} • {order.items} item(s) • placed {order.placedAt}</p>
          </StorefrontCard>
        ))}
      </StorefrontCardGrid>
    </AccountShell>
  </section>
</BaseLayout>
