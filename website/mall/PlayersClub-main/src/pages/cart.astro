---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Separator from "../components/Separator.astro";
import { storefrontAliases } from "../lib/sylius";

const title = "Cart | PCLIKA";

const products = await getCollection("products");
const productCatalog = products.map((product) => ({
  id: product.id,
  name: product.data.name,
  sku: product.data.sku,
  category: product.data.category,
  price: product.data.price,
  image: product.data.image.src,
}));
---

<BaseLayout title={title} description="Shopping cart">
  <section id="cart-page">
    <header class="title-header title-header--initial">
      <h2>Cart</h2>
      <a href="/" class="back-link">Continue Shopping</a>
    </header>
    <Separator />

    <div id="cart-empty" class="cart-empty">
      <div class="cart-empty__inner">
        <p class="cart-empty__title">Your cart is empty.</p>
        <p class="cart-empty__copy">Start with boards, modules, sensors, and bridge tools that fit your current prototype.</p>
        <a href="/" class="btn-checkout">Browse products</a>
      </div>
    </div>

    <div id="cart-contents" class="cart-contents" style="display:none;">
      <div class="cart-layout">
        <div class="cart-main">
          <div class="cart-head">
            <span>Product</span>
            <span>Unit Price</span>
            <span>Quantity</span>
            <span>Subtotal</span>
          </div>
          <div id="cart-items" class="cart-items"></div>
        </div>

        <aside class="cart-summary">
          <p class="cart-summary__eyebrow">Order Summary</p>
          <div class="cart-summary__rows">
            <div class="cart-summary__row">
              <span>Items</span>
              <strong id="cart-count">0</strong>
            </div>
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <strong id="cart-total">$0.00</strong>
            </div>
            <div class="cart-summary__row cart-summary__row--muted">
              <span>Shipping</span>
              <span>Calculated at checkout</span>
            </div>
          </div>
          <p class="cart-summary__note">Taxes, shipping, and payment method selection continue in the Sylius-aligned checkout flow.</p>
          <div class="cart-actions">
            <a class="btn-checkout" href={storefrontAliases.checkout}>Proceed to checkout</a>
            <a class="btn-checkout btn-checkout--secondary" href="/">Continue shopping</a>
            <button class="btn-checkout btn-checkout--ghost" id="btn-clear-cart" type="button">Clear cart</button>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .cart-empty {
    padding: 4rem 0 6rem;
  }

  .cart-empty__inner {
    max-width: 34rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    border: 1px solid var(--border-color);
    text-align: center;
  }

  .cart-empty__title {
    margin: 0 0 0.75rem;
    font-size: 1.3rem;
    font-weight: 700;
  }

  .cart-empty__copy {
    margin: 0 0 1.5rem;
    color: var(--color-text-alt);
    line-height: 1.55;
  }

  .cart-contents {
    padding: 1.5rem 0 6rem;
  }

  .cart-layout {
    display: grid;
    gap: 1.5rem;
  }

  @media screen and (min-width: 64em) {
    .cart-layout {
      grid-template-columns: minmax(0, 1.8fr) minmax(18rem, 24rem);
      align-items: start;
    }
  }

  .cart-main {
    min-width: 0;
  }

  .cart-head {
    display: none;
  }

  @media screen and (min-width: 64em) {
    .cart-head {
      display: grid;
      grid-template-columns: minmax(0, 1.8fr) 0.65fr 0.7fr 0.7fr;
      gap: 1rem;
      padding: 0 0 0.85rem;
      border-bottom: 1px solid var(--border-color);
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-text-alt);
    }
  }

  .cart-items {
    display: grid;
    gap: 1rem;
  }

  .cart-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.15rem;
    border: 1px solid var(--border-color);
    background: var(--color-bg);
  }

  @media screen and (min-width: 64em) {
    .cart-item {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
    }
  }

  .cart-item__product {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: start;
  }

  @media screen and (min-width: 48em) {
    .cart-item__product {
      flex-direction: row;
      align-items: start;
      flex: 1 1 auto;
      min-width: 0;
    }
  }

  .cart-item__thumb {
    display: block;
    flex: 0 0 6.25rem;
    width: 6.25rem;
    aspect-ratio: 1;
    background: var(--color-placeholder);
    border: 1px solid var(--border-color);
    overflow: hidden;
  }

  .cart-item__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__details {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .cart-item__meta {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-alt);
  }

  .cart-item__name {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .cart-item__sku {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-text-alt);
  }

  .cart-item__remove {
    width: fit-content;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-alt);
  }

  .cart-item__remove:hover {
    color: var(--color-text);
  }

  .cart-item__price,
  .cart-item__qty,
  .cart-item__subtotal {
    display: grid;
    gap: 0.25rem;
  }

  .cart-item__meta-row {
    display: grid;
    gap: 1rem;
  }

  @media screen and (min-width: 64em) {
    .cart-item__meta-row {
      display: contents;
    }

    .cart-item__price,
    .cart-item__qty,
    .cart-item__subtotal {
      min-width: 7rem;
      justify-items: start;
      align-content: center;
    }
  }

  .cart-item__label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-alt);
  }

  .cart-item__value {
    font-size: 1rem;
    font-weight: 700;
  }

  .cart-item__qty {
    gap: 0.5rem;
  }

  .cart-item__qty-controls {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    border: 1px solid var(--border-color);
  }

  .cart-item__qty-controls button {
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    border-right: 1px solid var(--border-color);
  }

  .cart-item__qty-controls button:last-child {
    border-right: 0;
    border-left: 1px solid var(--border-color);
  }

  .cart-item__qty-controls span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    height: 2.5rem;
    font-weight: 700;
  }

  .cart-summary {
    display: grid;
    gap: 1rem;
    padding: 1.2rem;
    border: 1px solid var(--border-color);
    background: var(--color-placeholder);
  }

  @media screen and (min-width: 64em) {
    .cart-summary {
      position: sticky;
      top: 6rem;
    }
  }

  .cart-summary__eyebrow {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-alt);
  }

  .cart-summary__rows {
    display: grid;
    gap: 0.75rem;
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.92rem;
  }

  .cart-summary__row strong {
    font-size: 1rem;
  }

  .cart-summary__row--muted {
    color: var(--color-text-alt);
  }

  .cart-summary__note {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-text-alt);
  }

  .cart-actions {
    display: grid;
    gap: 0.7rem;
  }

  .btn-checkout {
    background: var(--color-text);
    color: var(--color-bg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 3rem;
    padding: 0.8rem 1.2rem;
    border: 0;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-checkout:hover {
    opacity: 0.82;
  }

  .btn-checkout--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--border-color);
  }

  .btn-checkout--ghost {
    background: transparent;
    color: var(--color-text-alt);
    border: 1px solid var(--border-color);
  }

  .back-link {
    font-weight: 600;
    color: var(--color-text-alt);
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--color-text);
  }
</style>

<script define:vars={{ productCatalog }}>
  (function () {
    function getCart() {
      try { return JSON.parse(localStorage.getItem('_cart') || '[]'); } catch (e) { return []; }
    }

    function setCart(items) {
      localStorage.setItem('_cart', JSON.stringify(items));
    }

    function formatPrice(value) {
      return '$' + value.toFixed(2);
    }

    function parsePrice(value) {
      return parseFloat(String(value || '').replace(/[^0-9.]/g, '')) || 0;
    }

    function getProductMeta(item) {
      return productCatalog.find(function (product) {
        return (item.sku && product.sku === item.sku) || product.name === item.name;
      });
    }

    var empty = document.getElementById('cart-empty');
    var container = document.getElementById('cart-contents');
    var itemsEl = document.getElementById('cart-items');
    var totalEl = document.getElementById('cart-total');
    var countEl = document.getElementById('cart-count');
    var clearBtn = document.getElementById('btn-clear-cart');

    function render() {
      var cart = getCart();
      if (!empty || !container || !itemsEl || !totalEl || !countEl) return;

      if (!cart.length) {
        empty.style.display = 'block';
        container.style.display = 'none';
        return;
      }

      empty.style.display = 'none';
      container.style.display = 'block';

      var html = '';
      var total = 0;
      var count = 0;

      cart.forEach(function (item, i) {
        var product = getProductMeta(item) || {};
        var price = parsePrice(item.price || product.price);
        var qty = item.qty || 1;
        var subtotal = price * qty;
        var productUrl = product.id ? '/' + product.id : '#';
        var image = product.image || '/playersclub-og.jpg';
        var category = product.category || 'Hardware';
        var sku = item.sku || product.sku || 'N/A';

        total += subtotal;
        count += qty;

        html += '<article class="cart-item">';
        html += '  <div class="cart-item__product">';
        html += '    <a class="cart-item__thumb" href="' + productUrl + '">';
        html += '      <img src="' + image + '" alt="' + item.name + '">';
        html += '    </a>';
        html += '    <div class="cart-item__details">';
        html += '      <p class="cart-item__meta">' + category + '</p>';
        html += '      <h3 class="cart-item__name"><a href="' + productUrl + '">' + item.name + '</a></h3>';
        html += '      <p class="cart-item__sku">SKU: ' + sku + '</p>';
        html += '      <button class="cart-item__remove" type="button" data-remove="' + i + '">Remove</button>';
        html += '    </div>';
        html += '  </div>';
        html += '  <div class="cart-item__meta-row">';
        html += '  <div class="cart-item__price">';
        html += '    <span class="cart-item__label">Unit Price</span>';
        html += '    <span class="cart-item__value">' + formatPrice(price) + '</span>';
        html += '  </div>';
        html += '  <div class="cart-item__qty">';
        html += '    <span class="cart-item__label">Quantity</span>';
        html += '    <div class="cart-item__qty-controls">';
        html += '      <button type="button" data-minus="' + i + '">-</button>';
        html += '      <span>' + qty + '</span>';
        html += '      <button type="button" data-plus="' + i + '">+</button>';
        html += '    </div>';
        html += '  </div>';
        html += '  <div class="cart-item__subtotal">';
        html += '    <span class="cart-item__label">Subtotal</span>';
        html += '    <span class="cart-item__value">' + formatPrice(subtotal) + '</span>';
        html += '  </div>';
        html += '  </div>';
        html += '</article>';
      });

      itemsEl.innerHTML = html;
      totalEl.textContent = formatPrice(total);
      countEl.textContent = String(count);

      itemsEl.querySelectorAll('[data-minus]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var cart = getCart();
          var i = parseInt(btn.getAttribute('data-minus') || '0', 10);
          if (cart[i]) {
            cart[i].qty = Math.max(0, (cart[i].qty || 1) - 1);
            if (cart[i].qty === 0) cart.splice(i, 1);
            setCart(cart);
            render();
            updateBadge();
          }
        });
      });

      itemsEl.querySelectorAll('[data-plus]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var cart = getCart();
          var i = parseInt(btn.getAttribute('data-plus') || '0', 10);
          if (cart[i]) {
            cart[i].qty = (cart[i].qty || 1) + 1;
            setCart(cart);
            render();
            updateBadge();
          }
        });
      });

      itemsEl.querySelectorAll('[data-remove]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var cart = getCart();
          var i = parseInt(btn.getAttribute('data-remove') || '0', 10);
          if (cart[i]) {
            cart.splice(i, 1);
            setCart(cart);
            render();
            updateBadge();
          }
        });
      });
    }

    function updateBadge() {
      var cart = getCart();
      var count = cart.reduce(function (sum, item) { return sum + (item.qty || 1); }, 0);
      var badge = document.querySelector('.cart-badge');
      if (badge) {
        if (count > 0) {
          badge.textContent = String(count);
          badge.style.display = 'flex';
        } else {
          badge.style.display = 'none';
        }
      }
    }

    clearBtn?.addEventListener('click', function () {
      setCart([]);
      render();
      updateBadge();
    });

    render();
  })();
</script>
