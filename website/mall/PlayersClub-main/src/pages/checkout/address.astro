---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";
import StorefrontSection from "../../components/StorefrontSection.astro";
import StorefrontForm from "../../components/StorefrontForm.astro";
import StorefrontSummary from "../../components/StorefrontSummary.astro";
import { checkoutSummary, mockAddresses } from "../../lib/storefront";
import { syliusPaths } from "../../lib/sylius";

const title = "Checkout - Address | PCLIKA";
const defaultAddress = mockAddresses.find((address) => address.default) ?? mockAddresses[0];
---

<BaseLayout title={title} description="Collect billing and shipping address data in the Sylius checkout flow.">
  <section>
    <StorefrontSection
      eyebrow="Checkout Step 1"
      title="Address Information"
      description="This page mirrors the Sylius address step. It should ultimately submit billing and shipping data to the checkout order."
    />
    <Separator />

    <div class="checkout-layout">
      <div>
        <StorefrontForm action={syliusPaths.checkoutAddress()} method="post">
          <div class="storefront-form__grid storefront-form__grid--2">
            <label>
              <span>First name</span>
              <input name="shippingAddress[firstName]" value="Yaser" />
            </label>
            <label>
              <span>Last name</span>
              <input name="shippingAddress[lastName]" value="Dht" />
            </label>
          </div>

          <div class="storefront-form__grid storefront-form__grid--2">
            <label>
              <span>Email</span>
              <input type="email" name="customer[email]" value="9986650@qq.com" />
            </label>
            <label>
              <span>Phone</span>
              <input name="shippingAddress[phoneNumber]" value={defaultAddress.phone} />
            </label>
          </div>

          <label>
            <span>Street</span>
            <input name="shippingAddress[street]" value={defaultAddress.street} />
          </label>

          <div class="storefront-form__grid storefront-form__grid--2">
            <label>
              <span>City</span>
              <input name="shippingAddress[city]" value={defaultAddress.city} />
            </label>
            <label>
              <span>Province / State</span>
              <input name="shippingAddress[provinceName]" value={defaultAddress.province} />
            </label>
          </div>

          <div class="storefront-form__grid storefront-form__grid--2">
            <label>
              <span>Postcode</span>
              <input name="shippingAddress[postcode]" value={defaultAddress.postcode} />
            </label>
            <label>
              <span>Country</span>
              <select name="shippingAddress[countryCode]">
                <option selected value={defaultAddress.country}>{defaultAddress.country}</option>
                <option value="US">US</option>
                <option value="DE">DE</option>
                <option value="GB">GB</option>
              </select>
            </label>
          </div>

          <p class="storefront-help">Target Sylius route: <code>{syliusPaths.checkoutAddress()}</code>. Final implementation should serialize shipping and billing address collections exactly as Sylius expects.</p>

          <div class="storefront-form__actions">
            <a class="storefront-button storefront-button--secondary" href="/checkout">Back</a>
            <a class="storefront-button" href="/checkout/select-shipping">Continue to shipping</a>
          </div>
        </StorefrontForm>
      </div>

      <StorefrontSummary
        items={checkoutSummary.items}
        subtotal={checkoutSummary.subtotal}
        shipping={checkoutSummary.shipping}
        tax={checkoutSummary.tax}
        total={checkoutSummary.total}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .checkout-layout {
    display: grid;
    gap: 1.5rem;
    padding: 1.5rem 0 4rem;
  }

  @media screen and (min-width: 52em) {
    .checkout-layout {
      grid-template-columns: minmax(0, 1.7fr) minmax(18rem, 28rem);
      align-items: start;
    }
  }
</style>
