---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";
import StorefrontSection from "../../components/StorefrontSection.astro";
import StorefrontNotice from "../../components/StorefrontNotice.astro";
import StorefrontSummary from "../../components/StorefrontSummary.astro";
import { checkoutSummary } from "../../lib/storefront";
import { syliusPaths } from "../../lib/sylius";

const title = "Checkout - Start | PCLIKA";
---

<BaseLayout title={title} description="Start the Sylius-standard checkout flow for Pclika hardware orders.">
  <section>
    <StorefrontSection
      eyebrow="Sylius Checkout"
      title="Checkout Starts Here"
      description="This is the Astro storefront entry aligned to the Sylius checkout lifecycle: cart, address, shipping, payment, and completion."
    />
    <Separator />

    <div class="checkout-layout">
      <div class="checkout-main">
        <StorefrontNotice
          title="Current Integration Stage"
          body="This page is now aligned to the Sylius route structure. The next implementation step is wiring the form payloads and cart token directly to Sylius checkout actions."
        />

        <article class="checkout-step">
          <h3>Step 1. Review cart lines</h3>
          <p>Confirm the selected modules, development boards, and bundle contents before moving into address capture.</p>
          <a class="checkout-link" href={syliusPaths.cart()}>Go to Sylius cart summary</a>
        </article>

        <article class="checkout-step">
          <h3>Step 2. Continue to address</h3>
          <p>Once the cart is confirmed, the storefront should submit to the Sylius checkout state machine and redirect here.</p>
          <a class="checkout-link" href="/checkout/address">Continue to address step</a>
        </article>
      </div>

      <StorefrontSummary
        items={checkoutSummary.items}
        subtotal={checkoutSummary.subtotal}
        shipping={checkoutSummary.shipping}
        tax={checkoutSummary.tax}
        total={checkoutSummary.total}
      >
        <a class="checkout-link" href="/checkout/address">Start checkout</a>
      </StorefrontSummary>
    </div>
  </section>
</BaseLayout>

<style>
  .checkout-layout {
    display: grid;
    gap: 1.5rem;
    padding: 1.5rem 0 4rem;
  }

  @media screen and (min-width: 52em) {
    .checkout-layout {
      grid-template-columns: minmax(0, 1.6fr) minmax(18rem, 28rem);
      align-items: start;
    }
  }

  .checkout-main {
    display: grid;
    gap: 1rem;
  }

  .checkout-step {
    display: grid;
    gap: 0.6rem;
    padding: 1.15rem;
    border: 1px solid var(--border-color);
  }

  .checkout-step h3,
  .checkout-step p {
    margin: 0;
  }

  .checkout-step p {
    line-height: 1.5;
    color: var(--color-text-alt);
  }

  .checkout-link {
    font-size: 0.84rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
