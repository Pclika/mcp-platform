---
import BaseLayout from "../layouts/BaseLayout.astro";
import Separator from "../components/Separator.astro";
import StorefrontSection from "../components/StorefrontSection.astro";
import { storefrontAliases } from "../lib/sylius";

const title = "Forgot Password | PCLIKA";
---

<BaseLayout title={title} description="Request a password reset aligned with the Sylius storefront flow.">
  <section class="storefront-narrow">
    <StorefrontSection
      eyebrow="Account Recovery"
      title="Forgotten Password"
      description="Submit the email address of your store account to request a password reset token."
      compact
    />
    <Separator />

    <form class="storefront-form" id="forgot-password-form">
      <div id="forgot-password-message" class="storefront-feedback" style="display:none;"></div>
      <label>
        <span>Email</span>
        <input type="email" id="forgot-password-email" name="email" placeholder="you@example.com" required />
      </label>
      <p class="storefront-help">Use your account email to request a reset link. During this integration phase, the request is handled by the Pclika API layer.</p>
      <div class="storefront-form__actions">
        <button type="submit">Send reset link</button>
        <a class="storefront-button storefront-button--secondary" href={storefrontAliases.login}>Back to login</a>
      </div>
    </form>
  </section>
</BaseLayout>

<style>
  .storefront-narrow {
    max-width: 34rem;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .storefront-form {
    display: grid;
    gap: 1rem;
  }

  .storefront-form label {
    display: grid;
    gap: 0.35rem;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .storefront-form input {
    width: 100%;
    padding: 0.72rem 0.8rem;
    border: 1px solid var(--border-color);
    background: var(--color-bg);
    color: var(--color-text);
    font: inherit;
  }

  .storefront-form__actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .storefront-form button,
  .storefront-button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 0.85rem 1.4rem;
    border: 0;
    background: var(--color-text);
    color: var(--color-bg);
    font: inherit;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .storefront-button--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--border-color);
  }

  .storefront-help {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-text-alt);
  }

  .storefront-feedback {
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--border-color);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .storefront-feedback.is-error {
    border-color: #d32f2f;
    color: #d32f2f;
  }

  .storefront-feedback.is-success {
    border-color: #22b99a;
    color: #0d6b58;
  }
</style>

<script>
  document.getElementById('forgot-password-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var button = this.querySelector('button[type="submit"]');
    var message = document.getElementById('forgot-password-message');
    var email = document.getElementById('forgot-password-email').value;

    button.disabled = true;
    button.textContent = 'Sending...';
    message.style.display = 'none';
    message.className = 'storefront-feedback';

    try {
      var res = await fetch('/api/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      var data = await res.json();
      if (res.ok) {
        message.textContent = data.message || 'If the account exists, a reset link request has been recorded.';
        message.classList.add('is-success');
      } else {
        message.textContent = data.error || 'Unable to submit reset request.';
        message.classList.add('is-error');
      }
    } catch (err) {
      message.textContent = 'Connection error. Please try again.';
      message.classList.add('is-error');
    }

    message.style.display = 'block';
    button.disabled = false;
    button.textContent = 'Send reset link';
  });
</script>
