---
import BaseLayout from "../layouts/BaseLayout.astro";
import Separator from "../components/Separator.astro";
import StorefrontSection from "../components/StorefrontSection.astro";
import StorefrontForm from "../components/StorefrontForm.astro";
import { syliusPaths } from "../lib/sylius";

const title = "Forgot Password | PCLIKA";
---

<BaseLayout title={title} description="Request a password reset aligned with the Sylius storefront flow.">
  <section class="storefront-narrow">
    <StorefrontSection
      eyebrow="Account Recovery"
      title="Forgotten Password"
      description="Submit the email address of your store account to request a password reset token."
      compact
    />
    <Separator />

    <StorefrontForm action={syliusPaths.forgotPassword()} method="post">
      <label>
        <span>Email</span>
        <input type="email" name="_username" placeholder="you@example.com" />
      </label>
      <p class="storefront-help">Target Sylius route: <code>{syliusPaths.forgotPassword()}</code></p>
      <div class="storefront-form__actions">
        <button type="submit">Send reset link</button>
      </div>
    </StorefrontForm>
  </section>
</BaseLayout>

<style>
  .storefront-narrow {
    max-width: 34rem;
    margin: 0 auto;
    padding-bottom: 4rem;
  }
</style>
