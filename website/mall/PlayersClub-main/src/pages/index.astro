---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TextSlider from "../components/TextSlider.astro";
import Separator from "../components/Separator.astro";
import Tooltip from "../components/Tooltip.astro";

const allProducts = await getCollection("products");
const title = "PCLIKA — MCP Hardware Store";

const categories = ["All", "Board", "Sensor", "Display", "Driver", "Bridge", "Power", "Module"];
---

<BaseLayout title={title} description="MCP hardware store: boards, sensors, drivers, bridges and modular kits for AI-driven development.">
  <header class="title-header title-header--initial">
    <div class="mcpbase-hero">
      <p class="mcpbase-hero__eyebrow">Open hardware foundation for MCP-native builds</p>
      <h2 class="mcpbase-hero__title" data-mcpbase-title>
        <span class="mcpbase-hero__glow" aria-hidden="true"></span>
        <span class="mcpbase-hero__word">
          <TextSlider content="MCPBase" />
        </span>
      </h2>
      <p class="mcpbase-hero__subline">
        Boards, modules and deployable building blocks for Claude, Codex, Cursor and other AI-driven hardware workflows.
      </p>
    </div>
    <div>
      {categories.map(cat => (
        <button class="cat-btn" data-category={cat}>
          <TextSlider content={cat} />
        </button>
      ))}
    </div>
    <span id="product-count"><TextSlider content={allProducts.length} /></span>
  </header>
  <Separator />

  <section class="product-grid" id="grid" data-grid="products">
    {allProducts.map(product => (
      <a
        href={`/${product.id}`}
        class="product"
        data-category={product.data.category}
        style={`--image: url('${product.data.image.src}');`}
        data-product-name={product.data.name}
        data-product-sku={product.data.sku}
        data-product-category={product.data.category}
        data-product-price={product.data.price}
        data-astro-prefetch
        aria-label={product.data.name}
      ></a>
    ))}
  </section>

  <Tooltip grid="products" />
</BaseLayout>

<style>
  div {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 1rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  .cat-btn {
    color: var(--color-text-alt);
  }
  .cat-btn.active {
    color: var(--color-text);
  }

  .mcpbase-hero {
    position: relative;
    display: grid;
    gap: 0.35rem;
    align-self: stretch;
    padding: 0.2rem 0 0.3rem;
    min-width: 0;
  }
  .mcpbase-hero__eyebrow {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-alt);
  }
  .mcpbase-hero__title {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin: 0;
    min-height: 1em;
    isolation: isolate;
    cursor: default;
  }
  .mcpbase-hero__title.is-active .mcpbase-hero__glow {
    opacity: 1;
    transform: translateY(-50%) scaleX(1.08);
    filter: blur(24px);
  }
  .mcpbase-hero__title.is-active .mcpbase-hero__word {
    letter-spacing: 0.015em;
  }
  .mcpbase-hero__word {
    position: relative;
    z-index: 2;
    display: inline-flex;
    color: var(--color-text);
    text-shadow:
      0 0 0 rgba(34, 185, 154, 0),
      0 0 1px rgba(0, 0, 0, 0.05);
    animation: mcpbaseTextFloat 7s ease-in-out infinite;
  }
  .mcpbase-hero__glow {
    position: absolute;
    left: -0.6rem;
    right: -0.8rem;
    top: 50%;
    height: 1.4em;
    transform: translateY(-50%);
    background:
      linear-gradient(90deg, rgba(34, 185, 154, 0), rgba(34, 185, 154, 0.2), rgba(0, 0, 0, 0.08), rgba(34, 185, 154, 0.18), rgba(34, 185, 154, 0));
    filter: blur(18px);
    opacity: 0.78;
    z-index: 1;
    animation: mcpbaseGlowSweep 6s ease-in-out infinite;
    pointer-events: none;
  }
  .mcpbase-hero__subline {
    margin: 0;
    max-width: 28rem;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--color-text-alt);
  }

  .product-grid {
    position: relative;
    overflow: hidden;
    display: grid;
    width: 100%;
    grid-template-columns: repeat(2, calc(100% / 2));
    margin: 1rem 0 10rem;
    min-height: 400px;
  }
  @media screen and (min-width: 30em) {
    .product-grid {
      grid-template-columns: repeat(4, calc(100% / 4));
    }
  }
  @media screen and (min-width: 50em) {
    .product-grid {
      grid-template-columns: repeat(7, calc(100% / 7));
    }
  }

  a.product {
    background-image: var(--image);
    background-size: cover;
    background-position: 50% 0%;
    aspect-ratio: 0.8;
    display: block;
  }
  a.product.hidden {
    display: none;
  }

  @keyframes mcpbaseGlowSweep {
    0%,
    100% {
      opacity: 0.35;
      transform: translateY(-50%) scaleX(0.94);
      filter: blur(18px);
    }
    50% {
      opacity: 0.95;
      transform: translateY(-50%) scaleX(1.04);
      filter: blur(22px);
    }
  }

  @keyframes mcpbaseTextFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
      letter-spacing: 0;
    }
    50% {
      transform: translate3d(0, -0.03em, 0);
      letter-spacing: 0.01em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mcpbase-hero__word,
    .mcpbase-hero__glow {
      animation: none;
    }
  }

  @media screen and (max-width: 50em) {
    .mcpbase-hero {
      padding-bottom: 0.5rem;
    }
    .mcpbase-hero__subline {
      max-width: none;
      font-size: 0.76rem;
    }
  }
</style>

<script>
  // ── Cart badge sync ──
  function getCart() {
    try { return JSON.parse(localStorage.getItem('_cart') || '[]'); } catch(e) { return []; }
  }
  function updateBadge() {
    var cart = getCart();
    var count = cart.reduce(function(s, i) { return s + (i.qty || 1); }, 0);
    var badge = document.querySelector('.cart-badge');
    if (badge) {
      if (count > 0) { badge.textContent = count; badge.style.display = 'flex'; }
      else { badge.style.display = 'none'; }
    }
  }
  updateBadge();

  const btns = document.querySelectorAll('.cat-btn');
  const grid = document.getElementById('grid');
  const countEl = document.getElementById('product-count');
  const mcpbaseTitle = document.querySelector('[data-mcpbase-title]');

  if (mcpbaseTitle) {
    mcpbaseTitle.addEventListener('pointerenter', () => {
      mcpbaseTitle.classList.add('is-active');
    });
    mcpbaseTitle.addEventListener('pointerleave', () => {
      mcpbaseTitle.classList.remove('is-active');
    });
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = btn.dataset.category;
      const cards = grid.querySelectorAll('a.product');
      let visible = 0;

      cards.forEach(card => {
        if (cat === 'All' || card.dataset.category === cat) {
          card.classList.remove('hidden');
          visible++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Update heading + count
      const h2 = document.querySelector('.title-header--initial h2 .oh__inner');
      if (h2) h2.textContent = cat === 'All' ? 'MCPBase' : cat;
      const countSpan = countEl.querySelector('.oh__inner');
      if (countSpan) countSpan.textContent = visible;
    });
  });
</script>
