---
import BaseLayout from "../layouts/BaseLayout.astro";
import Separator from "../components/Separator.astro";
import { storefrontAliases, syliusPaths } from "../lib/sylius";

const title = "Sign In | PCLIKA";
---

<BaseLayout title={title} description="Sign in to your account">
  <section class="auth-page">
    <header class="title-header title-header--initial">
      <h2>Sign In</h2>
    </header>
    <Separator />
    <div class="auth-form">
      <div id="auth-error" class="auth-error" style="display:none;"></div>
      <p class="auth-meta">Storefront alias: <code>{storefrontAliases.login}</code> · Target Sylius route: <code>{syliusPaths.login()}</code></p>
      <form id="login-form">
        <label>
          <span>Email</span>
          <input type="email" id="login-email" placeholder="you@example.com" required />
        </label>
        <label>
          <span>Password</span>
          <input type="password" id="login-password" placeholder="Enter your password" required />
        </label>
        <button type="submit" id="login-btn">Sign In</button>
      </form>
      <p class="auth-alt">Forgot your password? <a href={storefrontAliases.forgotPassword}>Reset it here</a></p>
      <p class="auth-alt">Don't have an account? <a href={storefrontAliases.register}>Register</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .auth-page { max-width: 420px; margin: 0 auto; padding: 2rem 0 6rem; }
  .auth-error { color: #d32f2f; margin-bottom: 1rem; padding: 0.5rem; border: 1px solid #d32f2f; font-size: 0.85rem; }
  .auth-meta { color: var(--color-text-alt); font-size: 0.78rem; line-height: 1.5; margin: 0 0 1rem; }
  .auth-form label { display: block; margin-bottom: 1.25rem; }
  .auth-form span { display: block; font-weight: 700; font-size: 0.85rem; margin-bottom: 0.3rem; }
  .auth-form input {
    width: 100%; padding: 0.6rem 0.8rem; font-family: inherit;
    border: 1px solid var(--color-faded); background: var(--color-bg);
    font-size: 0.95rem;
  }
  .auth-form button {
    background: var(--color-text); color: var(--color-bg);
    font-family: inherit; font-weight: 700; font-size: 0.9rem;
    padding: 0.7rem 2rem; border: 0; cursor: pointer;
  }
  .auth-alt { margin-top: 1.5rem; font-size: 0.85rem; color: var(--color-text-alt); }
</style>

<script>
  document.getElementById('login-form')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('login-btn');
    var err = document.getElementById('auth-error');
    var email = document.getElementById('login-email').value;
    var password = document.getElementById('login-password').value;

    btn.disabled = true;
    btn.textContent = 'Signing in...';
    err.style.display = 'none';

    try {
      var res = await fetch('/api/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });
      var data = await res.json();
      if (res.ok) {
        localStorage.setItem('_token', data.token);
        if (data.user) localStorage.setItem('_user', JSON.stringify(data.user));
        window.location.href = storefrontAliases.account;
      } else {
        err.textContent = data.error || 'Login failed';
        err.style.display = 'block';
      }
    } catch (e) {
      err.textContent = 'Connection error. Please try again.';
      err.style.display = 'block';
    }
    btn.disabled = false;
    btn.textContent = 'Sign In';
  });
</script>
