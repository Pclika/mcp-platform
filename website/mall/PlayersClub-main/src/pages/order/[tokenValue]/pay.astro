---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import StorefrontSection from "../../../components/StorefrontSection.astro";
import StorefrontNotice from "../../../components/StorefrontNotice.astro";
import Separator from "../../../components/Separator.astro";
import { syliusPaths } from "../../../lib/sylius";

export const getStaticPaths = () => [
  { params: { tokenValue: "PCL-2026-1010" } },
  { params: { tokenValue: "PCL-2026-1011" } },
];

const { tokenValue = "ORDER_TOKEN" } = Astro.params;
const title = "Order Payment | PCLIKA";
---

<BaseLayout title={title} description="Order payment step aligned to the Sylius order pay route.">
  <section class="storefront-narrow">
    <StorefrontSection
      eyebrow="Sylius Payment Alias"
      title="Resume Order Payment"
      description="This page represents the Sylius order payment continuation route used after a pending or failed checkout payment."
      compact
    />
    <Separator />
    <StorefrontNotice
      title="Current Integration Stage"
      body={`Target Sylius route: ${syliusPaths.orderPay(tokenValue)}. Connect this page to the active payment session once checkout is fully handled by Sylius.`}
    />
    <p><a href={`/order/${tokenValue}`}>Return to order summary</a></p>
  </section>
</BaseLayout>

<style>
  .storefront-narrow {
    max-width: 38rem;
    margin: 0 auto;
    padding-bottom: 4rem;
  }
</style>
