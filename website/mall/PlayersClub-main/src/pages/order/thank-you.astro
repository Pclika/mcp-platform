---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";
import StorefrontSection from "../../components/StorefrontSection.astro";
import StorefrontCard from "../../components/StorefrontCard.astro";
import StorefrontCardGrid from "../../components/StorefrontCardGrid.astro";
import { storefrontAliases } from "../../lib/sylius";

const title = "Order Confirmed | PCLIKA";
---

<BaseLayout title={title} description="Order confirmation page aligned with Sylius thank-you flow.">
  <section>
    <StorefrontSection
      eyebrow="Order Confirmed"
      title="Thank You For Your Order"
      description="This page mirrors the Sylius thank-you step after checkout completion or payment return."
    />
    <Separator />

    <StorefrontCardGrid>
      <StorefrontCard title="Order Number" subtitle="PCL-2026-1010">
        <p>Your Pclika MCP hardware order has been created and queued for fulfillment review.</p>
      </StorefrontCard>
      <StorefrontCard title="What happens next" subtitle="Supply chain handoff">
        <ul>
          <li>Payment confirmation is recorded in the order timeline.</li>
          <li>Warehouse or factory handoff begins based on SKU mix.</li>
          <li>Tracking and invoice updates appear in the account area.</li>
        </ul>
      </StorefrontCard>
      <StorefrontCard title="Next actions" subtitle="Storefront follow-up routes">
        <a href={storefrontAliases.accountOrders} class="storefront-card__action">View account orders</a>
        <a href="/order/PCL-2026-1010" class="storefront-card__action">Open guest order</a>
      </StorefrontCard>
    </StorefrontCardGrid>
  </section>
</BaseLayout>
