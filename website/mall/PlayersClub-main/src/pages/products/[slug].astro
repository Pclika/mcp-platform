---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StorefrontSection from "../../components/StorefrontSection.astro";
import Separator from "../../components/Separator.astro";

export const getStaticPaths = async () => {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { slug: product.id },
  }));
};

const { slug } = Astro.params;
const target = `/${slug}`;
---

<BaseLayout title="Redirecting Product | PCLIKA" description="Redirecting Sylius-style product alias to the current product detail page.">
  <section class="redirect-page">
    <StorefrontSection
      eyebrow="Storefront Alias"
      title="Redirecting to Product Detail"
      description="This route keeps the Sylius product URL shape available while the current Astro product detail page remains the primary rendered page."
      compact
    />
    <Separator />
    <p class="redirect-copy">Continue to <a href={target}>{target}</a>.</p>
  </section>
</BaseLayout>

<script define:vars={{ target }}>
  window.location.replace(target);
</script>

<style>
  .redirect-page {
    max-width: 38rem;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .redirect-copy {
    color: var(--color-text-alt);
  }
</style>
