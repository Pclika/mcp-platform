---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Separator from "../../../../components/Separator.astro";
import StorefrontSection from "../../../../components/StorefrontSection.astro";
import StorefrontCardGrid from "../../../../components/StorefrontCardGrid.astro";
import StorefrontCard from "../../../../components/StorefrontCard.astro";

export const getStaticPaths = async () => {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
};

const { product } = Astro.props;
const title = `${product.data.name} Reviews | PCLIKA`;
const reviews = [
  {
    title: "Prototype-ready",
    body: "Fast bring-up, stable docs, and clean fit for AI-assisted hardware development loops.",
    author: "System Integrator",
  },
  {
    title: "Good for classroom kits",
    body: "Strong choice for guided lab environments and small-batch teaching deployments.",
    author: "Education Partner",
  },
];
---

<BaseLayout title={title} description="Product review listing aligned to Sylius storefront review routes.">
  <section>
    <StorefrontSection
      eyebrow="Product Reviews"
      title={`Reviews for ${product.data.name}`}
      description="This route should later render real review resources from the Sylius review subsystem."
    />
    <Separator />

    <p><a href={`/products/${product.id}/reviews/new`}>Write a review</a></p>

    <StorefrontCardGrid>
      {reviews.map((review) => (
        <StorefrontCard title={review.title} subtitle={review.author}>
          <p>{review.body}</p>
        </StorefrontCard>
      ))}
    </StorefrontCardGrid>
  </section>
</BaseLayout>
