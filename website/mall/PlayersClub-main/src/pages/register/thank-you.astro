---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";
import StorefrontSection from "../../components/StorefrontSection.astro";
import StorefrontNotice from "../../components/StorefrontNotice.astro";
import { storefrontAliases } from "../../lib/sylius";

const title = "Registration Complete | PCLIKA";
---

<BaseLayout title={title} description="Post-registration thank-you page aligned to Sylius storefront registration flow.">
  <section class="storefront-narrow">
    <StorefrontSection
      eyebrow="Welcome"
      title="Your Store Account Is Ready"
      description="This page mirrors the Sylius register thank-you state after successful customer account creation."
      compact
    />
    <Separator />
    <StorefrontNotice
      title="Next step"
      body="Continue browsing products, or go straight into your account center to manage addresses and future orders."
      href={storefrontAliases.account}
      hrefLabel="Open account center"
    />
  </section>
</BaseLayout>

<style>
  .storefront-narrow {
    max-width: 34rem;
    margin: 0 auto;
    padding-bottom: 4rem;
  }
</style>
