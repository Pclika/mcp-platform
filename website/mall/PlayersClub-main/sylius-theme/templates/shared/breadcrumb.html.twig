{#
 # Breadcrumb navigation — SEO + accessibility
 # Simple rendering using product data without custom Twig functions.
 #}
{% if hookable_metadata.context.product is defined %}
    {% set product = hookable_metadata.context.product %}
    <nav class="pc-breadcrumb" aria-label="{{ 'sylius.ui.breadcrumb'|trans }}">
        <a href="{{ path('sylius_shop_homepage') }}">{{ 'sylius.ui.home'|trans }}</a>
        {% if product.mainTaxon is defined and product.mainTaxon %}
            <span class="pc-breadcrumb__sep" aria-hidden="true">/</span>
            {% if product.mainTaxon.parent is not empty %}
                <a href="{{ path('sylius_shop_product_index', {'slug': product.mainTaxon.parent.slug, '_locale': product.mainTaxon.parent.translation.locale}) }}">{{ product.mainTaxon.parent.name }}</a>
            {% endif %}
            <span class="pc-breadcrumb__sep" aria-hidden="true">/</span>
            <a href="{{ path('sylius_shop_product_index', {'slug': product.mainTaxon.slug, '_locale': product.mainTaxon.translation.locale}) }}">{{ product.mainTaxon.name }}</a>
        {% endif %}
        <span class="pc-breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ product.name }}</span>
    </nav>
{% else %}
    <nav class="pc-breadcrumb" aria-label="{{ 'sylius.ui.breadcrumb'|trans }}">
        <a href="{{ path('sylius_shop_homepage') }}">{{ 'sylius.ui.home'|trans }}</a>
    </nav>
{% endif %}
