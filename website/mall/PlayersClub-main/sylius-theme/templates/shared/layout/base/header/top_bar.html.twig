{#
 # Header top bar — info message, currency switcher, locale switcher, cart count
 # International e-commerce standard: accessibility, multi-currency, multi-language
 #}
<div class="pc-topbar">
    <div class="pc-topbar__left">
        <span class="pc-topbar__msg">
            {% hook 'info_message' %}
        </span>
    </div>
    <div class="pc-topbar__right">
        {% if sylius.currencyCode is defined %}
            <span class="pc-topbar__currency" aria-label="Currency: {{ sylius.currencyCode }}">{{ sylius.currencyCode }}</span>
        {% endif %}
        {% if sylius.localeCode is defined %}
            <span class="pc-topbar__locale" aria-label="Language: {{ sylius.localeCode|upper }}">{{ sylius.localeCode|upper }}</span>
        {% endif %}
        <span class="pc-topbar__spacer" aria-hidden="true">|</span>
        <span class="pc-topbar__user">
            {% if app.user %}
                <a href="{{ path('sylius_shop_account_dashboard') }}">{{ 'sylius.ui.my_account'|trans }}</a>
            {% else %}
                <a href="{{ path('sylius_shop_login') }}">{{ 'sylius.ui.login'|trans }}</a>
                <span aria-hidden="true">/</span>
                <a href="{{ path('sylius_shop_register') }}">{{ 'sylius.ui.register'|trans }}</a>
            {% endif %}
        </span>
    </div>
</div>
