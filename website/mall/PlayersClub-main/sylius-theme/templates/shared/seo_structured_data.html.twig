{#
 # Skip to content + Schema.org SEO
 # Accessibility skip link + JSON-LD structured data for Organization
 #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "PCLIKA",
  "url": "https://mall.pclika.com/",
  "logo": "https://mall.pclika.com/logo.svg",
  "description": "MCP hardware store: boards, sensors, drivers, bridges and modular kits for AI-driven development.",
  "sameAs": [
    "https://github.com/Pclika",
    "https://pclika.com/"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "url": "{{ url('sylius_shop_contact_request') }}"
  }
}
</script>

{% if hookable_metadata.context.product is defined %}
    {% set product = hookable_metadata.context.product %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.name }}",
  "sku": "{{ product.code }}",
  "description": "{{ product.shortDescription|default(product.name) }}",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/{% if product.variants|length > 0 %}InStock{% else %}OutOfStock{% endif %}",
    "priceCurrency": "{{ sylius.currencyCode|default('USD') }}",
    "url": "{{ url('sylius_shop_product_show', {'slug': product.slug}) }}"
  }
}
</script>
{% endif %}
